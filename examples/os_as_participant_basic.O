#!/usr/bin/env O
# STEP-4: OS-as-participant.
#
# The running operating system becomes a first-class participant in the
# value model. The Nix lattice extends from three rungs to four:
#
#   NixExpr → Derivation → StorePath → System
#               instantiate    realise     activate
#
# A System value REFERS TO something in the world — the live profile —
# rather than carrying a content-addressed snapshot. Equality is by profile
# path, not by current generation. Querying its state requires an
# out-of-band call.
#
# SAFETY: activate() defaults to dry_run=true at the language level, AND
# the actual subprocess (`switch-to-configuration switch`) is gated by the
# environment variable O_LANG_ALLOW_ACTIVATION=1. Running this example
# without the env var set produces a dry-activate (logs only); running
# WITH the env var set would actually switch the system.

let cfg     = nix_expr^( (import <nixpkgs/nixos> { configuration = ./configuration.nix; }).system )_nix_expr
let drv     = instantiate($cfg)      # rung climb: NixExpr → Derivation
let path    = realise($drv)          # rung climb: Derivation → StorePath
let active  = activate($path)        # rung climb: StorePath → System (dry-run by default)

# Equivalently, as a single chained expression:
#   let active = activate(realise(instantiate($cfg)))
#
# The executor walks the chain end-to-end under Eager: instantiates the
# expression, realises the derivation, activates the closure. Each rung
# climb is a Request that the executor performs in sequence.

# current_system() inspects the live profile reference without invoking any
# state-changing transition. Useful for "where am I" queries that compose
# with activate() chains.
let here = current_system()

markdown^(
# Step-4 OS-as-participant

- configuration (NixExpr):   `$cfg`
- system derivation (drv):   `$drv`
- system closure (path):     `$path`
- activated profile (System): `$active`
- current system reference:  `$here`
)_markdown
